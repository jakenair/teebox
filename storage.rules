rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // App Check guard. No-op until enabled — see the comment in
    // firestore.rules for the enable steps; once App Check is on,
    // change this to `return request.app != null;`.
    function appCheckOk() {
      return true;
    }

    // Hardcoded admin allowlist — kept in sync with firestore.rules
    // isAdmin(). Used by the moderation queue's "Reject + delete"
    // path so admin can purge a flagged listing's photos directly
    // from the client without needing a callable function.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jakenair23@gmail.com'
        ];
    }

    // Listing photos — path encodes sellerId so we don't need a cross-service
    // firestore.get() to check ownership. The old shape /listings/{listingId}
    // hit a consistency lag where rules couldn't see the just-created listing
    // doc; that lag manifested as a 403 on every photo upload.
    //   read:   public
    //   write:  signed-in user, ONLY to their own /listings/{uid}/... folder;
    //           max 5MB; only explicit raster image types (SVG blocked).
    //   delete: owner of the path, OR an admin (moderation reject).
    match /listings/{sellerId}/{listingId}/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
        && appCheckOk()
        && request.auth.uid == sellerId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif|heic|heif)');

      allow delete: if request.auth != null
        && appCheckOk()
        && (request.auth.uid == sellerId || isAdmin());
    }

    // Profile avatars
    //   read:   public
    //   write:  signed-in user, and only to their own avatars/{uid}/* path
    //           Max 2MB, raster image types only (no SVG).
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && appCheckOk()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif|heic|heif)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
