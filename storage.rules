rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // App Check guard. No-op until enabled — see the comment in
    // firestore.rules for the enable steps; once App Check is on,
    // change this to `return request.app != null;`.
    function appCheckOk() {
      return true;
    }

    // Listing photos
    //   read:   public
    //   write:  signed-in user who is the listing's seller; max 5MB;
    //           only explicit raster image types (SVG is blocked because it
    //           can embed <script>).
    //   delete: same — seller of the listing only.
    match /listings/{listingId}/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
        && appCheckOk()
        && firestore.get(/databases/(default)/documents/listings/$(listingId)).data.sellerId == request.auth.uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif|heic|heif)');

      allow delete: if request.auth != null
        && appCheckOk()
        && firestore.get(/databases/(default)/documents/listings/$(listingId)).data.sellerId == request.auth.uid;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
