# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
firebase-debug.*.log*

# Firebase cache
.firebase/

# Firebase config

# Uncomment this if you'd like others to create their own Firebase project.
# For a team working on the same Firebase project(s), it is recommended to leave
# it commented so all members can deploy to the same project(s) in .firebaserc.
# .firebaserc

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
functions/node_modules/
.DS_Store

# Capacitor build output (regenerated by `npm run build:web`)
dist/

# Android native build artifacts
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/captures/
android/app/release/
*.jks
*.keystore

# Apple signing secrets — APNs auth keys, provisioning profiles, certs.
# These must never be committed (the APNs .p8 lives outside the repo).
*.p8
*.mobileprovision
*.p12
*.cer

# iOS native build artifacts (the platform itself is committed; build
# folders + Pods are not — Pods regenerates on `pod install`)
ios/App/Pods/
ios/App/build/
ios/App/.build/
ios/App/DerivedData/
ios/.idea/
ios/build/

# Xcode user-specific state — UI selection, breakpoints, recent files,
# workspace expanded-folders. Never useful in git; mutates with every
# Xcode interaction and was a residual source of working-tree churn.
**/xcuserdata/
*.xcuserstate

# Capacitor sync intermediates
.capacitor/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env

# dataconnect generated files
.dataconnect
.claude/

# Logo Bingo audit run output (regenerated per-invocation; baseline IS committed).
scripts/logo-audit-report.json

# Internal-only docs — audits, security reviews, plans, QA scripts. The repo is
# PUBLIC (GitHub Pages from root); these must NEVER be committed/served. They
# were previously untracked only by omission — ignore the whole dir so a stray
# `git add -A` can't leak them.
.internal-docs/
