rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // App Check guard. Currently a no-op: App Check is not yet
    // configured in the Firebase console. After enabling App Check
    // (see the comment block in index.html that initializes
    // ReCaptchaEnterpriseProvider), change this to:
    //     return request.app != null;
    // and redeploy. Every write rule below already calls this
    // function, so flipping it on closes the door without any
    // further rule edits.
    function appCheckOk() {
      return true;
    }

    // Hardcoded admin email allowlist. Used by the moderation queue
    // (flaggedListings collection) and admin-only listing status
    // updates. Email is on the JWT — Firebase Auth populates
    // request.auth.token.email when the provider supplies one
    // (Google, email/password, Apple-with-email). Phone-only sign-ins
    // have no email so this check naturally excludes them.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jakenair23@gmail.com'
        ];
    }

    // Email-verified gate. Used to block write-heavy actions (listing
    // creation, profile-significant user-doc updates) until the user
    // has clicked the verification link. Phone-only sign-ins don't have
    // this claim, so we accept either email_verified==true OR phone
    // sign-in (token.firebase.sign_in_provider == 'phone') so we don't
    // lock phone users out of basic flows.
    function isEmailVerified() {
      return request.auth != null
        && (request.auth.token.email_verified == true
            || request.auth.token.firebase.sign_in_provider == 'phone');
    }

    // Stripe Connect KYC gate. Reads the seller's user doc and asserts
    // `stripeChargesEnabled == true`. The user doc is the source of
    // truth — it's written by the Connect webhook
    // (functions/index.js:839) on every Stripe `account.updated` event
    // and refreshed by the getStripeAccountStatus callable. We do NOT
    // trust a client-side claim here because clients can't be allowed
    // to flip their own onboarding state.
    function sellerStripeReady(uid) {
      return get(/databases/$(database)/documents/users/$(uid))
        .data.get('stripeChargesEnabled', false) == true;
    }

    // ─────────────────────────────────────────────
    // LISTINGS
    //   read:   public
    //   create: signed-in, seller is self, schema validated, `status == 'active'`
    //           no server-owned fields (soldAt/soldTo/pendingBuyer/etc.)
    //   update: only while status == 'active'; seller can change a strict
    //           whitelist of user-editable fields. Status/soldAt/soldTo/
    //           pendingBuyer/etc. are server-owned and only writable via
    //           Admin SDK (Cloud Functions).
    //   delete: seller only
    // ─────────────────────────────────────────────
    match /listings/{listingId} {
      allow read: if true;

      allow create: if request.auth != null
        && appCheckOk()
        && isEmailVerified()
        && request.resource.data.sellerId == request.auth.uid
        && isValidListingCreate(request.resource.data)
        // Stripe Connect KYC gate (C2). Sellers must have a Connect
        // account with charges_enabled=true before they can publish a
        // listing. The user-doc field is kept in sync by the
        // `stripeConnectAccountUpdated` webhook handler
        // (functions/index.js:839) and by getStripeAccountStatus
        // (functions/index.js:4177). Client-side `submitListing` is the
        // primary gate; this rule is the backstop.
        && sellerStripeReady(request.auth.uid);

      allow update: if request.auth != null
        && appCheckOk()
        && resource.data.sellerId == request.auth.uid
        && isValidListingUpdate(request.resource.data, resource.data);

      // Admin moderation update — admin emails can flip status and
      // clear/replace moderationFlags on any listing. Limited to
      // those two fields plus an updatedAt bump. Used by the manual
      // moderation queue UI (?admin=moderation).
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['status','moderationFlags','updatedAt']);

      allow delete: if request.auth != null
        && appCheckOk()
        && resource.data.sellerId == request.auth.uid
        && resource.data.get('status', 'active') != 'sold';

      // Admin reject — admin emails can delete any listing (for the
      // "Reject + delete" button in the moderation queue).
      allow delete: if isAdmin();
    }

    function isValidListingCreate(d) {
      return d.keys().hasAll(['sellerId','title','brand','cat','ask','bid','condition','createdAt','status','expiresAt'])
        // Defense-in-depth field whitelist. Anything not in this list is
        // rejected — prevents a malicious client from stuffing arbitrary
        // server-owned fields (e.g. `disputed`, `refunded`, `tier`,
        // `featured`) onto a brand-new listing where the per-field
        // checks below might not catch it.
        && d.keys().hasOnly([
             'sellerId','title','brand','cat','ask','bid','condition',
             'createdAt','status','expiresAt','desc','photos','emoji',
             'badge','volume','change','quantity','quantitySold',
             'requiresAuth','authReviewState'])
        && d.status == 'active'
        && d.title is string && d.title.size() > 0 && d.title.size() <= 120
        && d.brand is string && d.brand.size() > 0 && d.brand.size() <= 60
        && d.cat is string && d.cat.size() > 0 && d.cat.size() <= 40
        && d.condition is string && d.condition.size() > 0 && d.condition.size() <= 40
        && d.ask is number && d.ask > 0 && d.ask < 1000000
        && d.bid is number && d.bid >= 0 && d.bid < 1000000
        && (!('desc' in d.keys()) || (d.desc is string && d.desc.size() <= 4000))
        && (!('photos' in d.keys()) || (d.photos is list && d.photos.size() <= 10))
        && (!('emoji' in d.keys()) || (d.emoji is string && d.emoji.size() <= 16))
        && (!('badge' in d.keys()) || (d.badge is string && d.badge.size() <= 16))
        && (!('volume' in d.keys()) || d.volume == 0)
        && (!('change' in d.keys()) || d.change == 0)
        // Multi-quantity stock. Sellers can list 1–99 units; quantitySold
        // is server-managed by createPaymentIntent and the Stripe webhook
        // — clients can only seed it to 0 on create.
        && (!('quantity' in d.keys()) || (d.quantity is number && d.quantity >= 1 && d.quantity <= 99))
        && (!('quantitySold' in d.keys()) || d.quantitySold == 0)
        // High-value verification badge. Boolean flag the client sets at
        // create-time; an admin (Admin SDK) flips authReviewState later.
        && (!('requiresAuth' in d.keys()) || d.requiresAuth is bool)
        && (!('authReviewState' in d.keys())
            || d.authReviewState in ['na','pending'])
        // Per-field deny list (kept for clarity even though hasOnly()
        // above already enforces it — easier to audit at a glance).
        && !('sellerPhone' in d.keys())
        && !('soldAt' in d.keys())
        && !('soldTo' in d.keys())
        && !('orderId' in d.keys())
        && !('pendingBuyer' in d.keys())
        && !('pendingUntil' in d.keys())
        && !('pendingPaymentIntentId' in d.keys())
        // Analytics counters are server-owned (Cloud Functions only).
        // Clients cannot seed or overwrite them on create. The view
        // counter is sharded across views_0..views_9 (SCALING_AUDIT #2);
        // `views` is the legacy pre-shard field, kept readable for
        // backward compat. None are client-writable.
        && !('views' in d.keys())
        && !('views_0' in d.keys())
        && !('views_1' in d.keys())
        && !('views_2' in d.keys())
        && !('views_3' in d.keys())
        && !('views_4' in d.keys())
        && !('views_5' in d.keys())
        && !('views_6' in d.keys())
        && !('views_7' in d.keys())
        && !('views_8' in d.keys())
        && !('views_9' in d.keys())
        && !('watchlistCount' in d.keys())
        && !('messageCount' in d.keys());
    }

    function isValidListingUpdate(next, prev) {
      return (prev.get('status', 'active') == 'active' || prev.get('status', 'active') == 'expired')
        && next.sellerId == prev.sellerId
        // Sellers may flip an expired listing back to active when they
        // touch `expiresAt` (renewal). All other status transitions are
        // server-only.
        && (next.get('status', 'active') == prev.get('status', 'active')
            || (prev.get('status', 'active') == 'expired' && next.get('status', 'active') == 'active'))
        // Analytics counters (views/watchlistCount/messageCount) are
        // intentionally excluded from this whitelist — they're written
        // by Cloud Functions only.
        && next.diff(prev).affectedKeys().hasOnly(
             ['title','brand','cat','ask','bid','condition','desc','photos','emoji','badge','updatedAt','expiresAt','status'])
        && (!('title' in next.keys()) || (next.title is string && next.title.size() > 0 && next.title.size() <= 120))
        && (!('brand' in next.keys()) || (next.brand is string && next.brand.size() > 0 && next.brand.size() <= 60))
        && (!('cat' in next.keys()) || (next.cat is string && next.cat.size() <= 40))
        && (!('condition' in next.keys()) || (next.condition is string && next.condition.size() <= 40))
        && (!('desc' in next.keys()) || (next.desc is string && next.desc.size() <= 4000))
        && (!('ask' in next.keys()) || (next.ask is number && next.ask > 0 && next.ask < 1000000))
        && (!('bid' in next.keys()) || (next.bid is number && next.bid >= 0 && next.bid < 1000000))
        && (!('photos' in next.keys()) || (next.photos is list && next.photos.size() <= 10))
        && (!('emoji' in next.keys()) || (next.emoji is string && next.emoji.size() <= 16))
        && (!('badge' in next.keys()) || (next.badge is string && next.badge.size() <= 16));
    }

    // ─────────────────────────────────────────────
    // USERS
    //   read:   self only
    //   create/update: self only, whitelist of user-editable fields.
    //                  Server-only fields (NEVER writable from the client):
    //                    sellerVerified, sellerVerifiedAt — set by
    //                      requestSellerVerification callable
    //                    stripeAccountId, stripeChargesEnabled,
    //                    stripePayoutsEnabled, stripeDetailsSubmitted,
    //                    stripeRequirementsCount, stripeAccountUpdatedAt,
    //                    stripeAccountCreatedAt — Stripe Connect onboarding
    //                      + account.updated webhook
    //                    stripeCustomerId, stripeCustomerCreatedAt —
    //                      createSubscriptionCheckout callable
    //                    tier, proSubscriptionId, proSubscriptionStatus,
    //                    proSubscriptionUpdatedAt, proCurrentPeriodEnd,
    //                    proCancelAtPeriodEnd — customer.subscription.*
    //                      events in stripeWebhook
    //                  These are enforced by the hasOnly() whitelist below;
    //                  any client write that includes them is rejected.
    //   delete: never from client
    // ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Strict allow-list. Any field not listed here is server-managed and
      // cannot be written by clients. Server-only fields explicitly include
      // (non-exhaustive): emailPrefs, emailPrefsUpdatedAt, emailSuppressed,
      // sellerVerified, tier, proSubscriptionStatus, frozen, frozenAt,
      // marketingConsent (GDPR audit trail — see GDPR_CONSENT_SCHEMA.md;
      // client MUST use the updateMarketingConsent callable), and
      // marketingBannerDismissedAt (set via dismissMarketingBanner callable).
      allow create: if request.auth != null && request.auth.uid == userId
        && appCheckOk()
        && request.resource.data.keys().hasOnly(
             ['phone','termsAgreed','termsAgreedAt','displayName','watchlist','blocked']);

      // Same allow-list on update. GDPR consent fields (marketingConsent,
      // marketingBannerDismissedAt) are deliberately excluded — they must
      // round-trip through the updateMarketingConsent /
      // dismissMarketingBanner callables so the server can stamp
      // serverTimestamp() and append the audit-trail history. A diff that
      // touches a server-only field is rejected outright (hasOnly() is
      // exact-match, not subset).
      allow update: if request.auth != null && request.auth.uid == userId
        && appCheckOk()
        && isEmailVerified()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['phone','termsAgreed','termsAgreedAt','displayName','watchlist','blocked']);

      allow delete: if false;

      // Saved searches subcollection — fully owned by the user.
      match /savedSearches/{ssId} {
        allow read, create, delete: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
      }

      // FCM tokens — owner reads & writes (writes their own token on
      // permission grant). Cloud Function reads via Admin SDK to dispatch.
      match /fcmTokens/{token} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // In-app notifications subcollection — recipient reads, can mark
      // read; only Cloud Functions write new notifications.
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if false;
        allow update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read','readAt']);
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Watchlist subcollection — owner-only read/write. Cloud Functions
      // read via collectionGroup queries (Admin SDK bypasses rules).
      match /watchlist/{listingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Logo Bingo durable game mirror. Doc id is the YYYY-MM-DD UTC date.
      // Written exclusively by the syncBingoProgress callable (Admin SDK
      // bypasses these rules); the local localStorage copy is the
      // source of truth for the running game. Owner can read so the
      // client can hydrate cross-device once we wire that up.
      match /bingoGames/{date} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if false;
      }
    }

    // pricesIndex — server-only state for price-drop diffing.
    match /pricesIndex/{listingId} {
      allow read, write: if false;
    }

    // processedStripeEvents — server-only marker collection used by
    // the Stripe webhook to deduplicate redelivered events. Doc id
    // is the Stripe event.id; presence of the doc means we already
    // processed that event.
    match /processedStripeEvents/{eventId} {
      allow read, write: if false;
    }

    // pendingOrders — server-only placeholder for payment_intents that
    // are still in the `processing` state (ACH, etc.). The order doc
    // is created only on payment_intent.succeeded.
    match /pendingOrders/{piId} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────
    // ORDERS — buyer/seller can read; client cannot create (Stripe
    // webhook only). Buyer can confirm delivery; seller can mark
    // shipped + add tracking. Anything else is server-only.
    // (Rule defined below in the original ORDERS block — see update
    // permissions added there.)
    // ─────────────────────────────────────────────

    // ─────────────────────────────────────────────
    // DISPUTES — id == orderId. Buyer of the order can create.
    //   read:   buyer or seller of the dispute
    //   write:  buyer creates once
    // ─────────────────────────────────────────────
    match /disputes/{orderId} {
      allow read: if request.auth != null
        && (resource.data.buyerId == request.auth.uid
            || resource.data.sellerId == request.auth.uid);
      allow create: if request.auth != null
        && appCheckOk()
        && request.resource.data.buyerId == request.auth.uid
        && exists(/databases/$(database)/documents/orders/$(orderId))
        && get(/databases/$(database)/documents/orders/$(orderId)).data.buyerId == request.auth.uid
        && request.resource.data.sellerId
             == get(/databases/$(database)/documents/orders/$(orderId)).data.sellerId
        && request.resource.data.keys().hasAll(['buyerId','sellerId','reason','status','createdAt'])
        && request.resource.data.status == 'open'
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 60
        && (!('detail' in request.resource.data.keys())
            || (request.resource.data.detail is string && request.resource.data.detail.size() <= 4000));
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // REPORTS — abuse reports for the admin queue.
    //   Anyone signed in can create; admin reads via this rule
    //   (was Admin-SDK-only) so the moderation UI can hydrate.
    //   targetType is constrained to a known enum so we don't get
    //   garbage tags from a future client typo.
    // ─────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
      allow create: if request.auth != null
        && appCheckOk()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.keys().hasAll(['reporterId','targetType','targetUid','reason','createdAt'])
        && request.resource.data.targetType is string
        && request.resource.data.targetType in ['listing','user','message','review']
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 60
        && request.resource.data.reason in [
             'counterfeit','off_platform','inappropriate_content','scam',
             'harassment','stolen_goods','wrong_category','other',
             'spam','inappropriate','off-topic'
           ]
        && (!('details' in request.resource.data.keys())
            || (request.resource.data.details is string
                && request.resource.data.details.size() <= 500))
        && (!('targetId' in request.resource.data.keys())
            || (request.resource.data.targetId is string
                && request.resource.data.targetId.size() <= 200))
        && (!('messageId' in request.resource.data.keys())
            || (request.resource.data.messageId is string
                && request.resource.data.messageId.size() <= 200))
        && (!('conversationId' in request.resource.data.keys())
            || (request.resource.data.conversationId is string
                && request.resource.data.conversationId.size() <= 200))
        && (!('status' in request.resource.data.keys())
            || (request.resource.data.status is string
                && request.resource.data.status in ['open','reviewing','resolved','dismissed']));
    }

    // ─────────────────────────────────────────────
    // ADMIN ACTIONS — append-only audit log written by Cloud
    //   Functions when an admin bans / suspends / takes down. Clients
    //   cannot write; admins can read for the moderation UI.
    // ─────────────────────────────────────────────
    match /adminActions/{actionId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // BIDS — bid offers a buyer makes on a listing.
    //   read:   buyer of the bid OR seller of the referenced listing
    //   create: signed-in, buyerId == self, NOT the seller, amount cap
    //   update: server-only (status flips via Cloud Function)
    //   delete: bidder may withdraw an open bid; otherwise no
    // ─────────────────────────────────────────────
    match /bids/{bidId} {
      allow read: if request.auth != null
        && (resource.data.buyerId == request.auth.uid
            || resource.data.sellerId == request.auth.uid);

      allow create: if request.auth != null
        && appCheckOk()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.keys().hasAll(
             ['listingId','buyerId','sellerId','amountCents','status','createdAt'])
        && request.resource.data.listingId is string
        && request.resource.data.listingId.size() > 0
        && request.resource.data.listingId.size() <= 128
        && exists(/databases/$(database)/documents/listings/$(request.resource.data.listingId))
        && request.resource.data.sellerId
             == get(/databases/$(database)/documents/listings/$(request.resource.data.listingId)).data.sellerId
        && request.resource.data.sellerId != request.auth.uid
        && request.resource.data.amountCents is int
        && request.resource.data.amountCents > 0
        && request.resource.data.amountCents < 100000000
        && request.resource.data.status == 'open';

      allow update: if false;

      allow delete: if request.auth != null
        && resource.data.buyerId == request.auth.uid
        && resource.data.status == 'open';

      // Counter-offer subcollection — buyer or seller of the parent
      // bid can append, immutable thereafter.
      match /counters/{counterId} {
        function bid() { return get(/databases/$(database)/documents/bids/$(bidId)).data; }
        allow read: if request.auth != null
          && (request.auth.uid == bid().buyerId || request.auth.uid == bid().sellerId);
        allow create: if request.auth != null
          && appCheckOk()
          && request.resource.data.from == request.auth.uid
          && (request.auth.uid == bid().buyerId || request.auth.uid == bid().sellerId)
          && request.resource.data.kind in ['accept','counter','reject']
          && request.resource.data.amountCents is int
          && request.resource.data.amountCents > 0
          && request.resource.data.amountCents < 100000000;
        allow update, delete: if false;
      }
    }

    // ─────────────────────────────────────────────
    // REVIEWS — two-way review system after a paid order.
    //   Doc id is `{orderId}_buyer` (buyer reviews seller) or
    //   `{orderId}_seller` (seller reviews buyer). One per role per
    //   order, idempotent. The `role` field must match the id suffix.
    //
    //   read:   public
    //   create: signed-in, party of the matching order matching the
    //           role; valid 1-5 rating; role is 'buyer' or 'seller'.
    //   update/delete: never (immutable record)
    // ─────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if request.auth != null
        && appCheckOk()
        && request.resource.data.keys().hasAll(['buyerId','sellerId','rating','role','orderId','createdAt'])
        && request.resource.data.role in ['buyer','seller']
        && reviewId == request.resource.data.orderId + '_' + request.resource.data.role
        && exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
        && request.resource.data.buyerId
             == get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.buyerId
        && request.resource.data.sellerId
             == get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.sellerId
        // Buyer-role review is authored by the buyer; seller-role
        // review is authored by the seller. Authorship is enforced by
        // the role suffix in the id, not a separate authorId field.
        && (
          (request.resource.data.role == 'buyer'
            && request.resource.data.buyerId == request.auth.uid)
          ||
          (request.resource.data.role == 'seller'
            && request.resource.data.sellerId == request.auth.uid)
        )
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && (!('comment' in request.resource.data.keys())
            || (request.resource.data.comment is string
                && request.resource.data.comment.size() <= 2000));

      allow update, delete: if false;

      // ─────────────────────────────────────────────
      // HELPFUL VOTES (subcollection) — TODO: Wave 2B added this; needs
      // admin review. Each user gets one doc keyed by their uid; vote
      // value is 'yes' | 'no'. Public read so anyone can render the
      // count. Owner-only write.
      // ─────────────────────────────────────────────
      match /helpfulVotes/{userId} {
        allow read: if true;
        // Votes are immutable once cast — prevents spam-flip cost attack.
        // To change a vote, user must delete then re-create.
        allow create: if request.auth != null
          && request.auth.uid == userId
          && appCheckOk()
          && request.resource.data.vote in ['yes','no'];
        allow update: if false;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─────────────────────────────────────────────
    // NOTIFICATIONS — in-app notifications (price drops, offers, etc.)
    // Read by recipient only. Writes are server-only (Cloud Function);
    // a client can mark its own notification as read (`read: true`).
    // ─────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if false; // server only
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read','readAt']);
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // PRICE HISTORY — denormalized rollup of past completed sales per
    // model, written by the Stripe webhook (Admin SDK). Public read so
    // anyone can see the sparkline on a listing detail.
    // ─────────────────────────────────────────────
    match /priceHistory/{model} {
      allow read: if true;
      allow write: if false;
    }

    // ─────────────────────────────────────────────
    // GLOBAL STATS — single denormalized doc `globalStats/all` that the
    // homepage reads to render hero volume + sold count. Bumped by the
    // Stripe order-success webhook via FieldValue.increment (Admin SDK
    // bypasses these rules). Public read so the hero pill works for
    // signed-out visitors. Backfilled once via the admin-only
    // `backfillGlobalStats` callable.
    // ─────────────────────────────────────────────
    match /globalStats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ─────────────────────────────────────────────
    // PROFILES — public read, owner write. Schema-validated. Avatars
    // live in Storage at avatars/{uid}/...
    //
    // Strict field whitelist to prevent shenanigans. The aggregate
    // analytics fields (reviewCount, avgRating, fiveStarPct,
    // salesCount, totalRevenue, lastSaleAt, lastReviewAt) are
    // server-owned: they're written by Cloud Functions via the Admin
    // SDK, never by the client. Same for pinnedListingId pin/unpin if
    // we ever wire it through a callable — for now it's user-editable.
    //
    // SERVER-OWNED FIELDS (written via Admin SDK, NEVER from client):
    //   reviewCount, avgRating, fiveStarPct, salesCount, totalRevenue,
    //   lastSaleAt, lastReviewAt — review aggregates
    //   isPro, isProUpdatedAt — Pro Seller flag mirrored from
    //     users/{uid}.tier by the customer.subscription.* webhook so
    //     that other users (who can't read users/{uid}) can see the pill
    // The client-write whitelists below intentionally exclude these so
    // any client write touching them is rejected by hasOnly().
    // ─────────────────────────────────────────────
    match /profiles/{userId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && appCheckOk()
        && request.resource.data.keys().hasOnly(
             ['displayName','bio','avatarUrl','location','handicap',
              'golfBag','pinnedListingId','updatedAt'])
        && isValidProfile(request.resource.data);

      allow update: if request.auth != null
        && request.auth.uid == userId
        && appCheckOk()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['displayName','bio','avatarUrl','location','handicap',
              'golfBag','pinnedListingId','updatedAt'])
        && isValidProfile(request.resource.data);

      allow delete: if false;
    }

    function isValidProfile(d) {
      return (!('displayName' in d.keys()) || (d.displayName is string && d.displayName.size() <= 60))
        && (!('bio' in d.keys())         || (d.bio is string && d.bio.size() <= 600))
        && (!('avatarUrl' in d.keys())   || (d.avatarUrl is string && d.avatarUrl.size() <= 1024))
        && (!('location' in d.keys())    || (d.location is string && d.location.size() <= 80))
        && (!('handicap' in d.keys())    || (d.handicap is number && d.handicap >= -10 && d.handicap <= 54))
        && (!('golfBag' in d.keys())     || (d.golfBag is list
                                              && d.golfBag.size() <= 14))
        && (!('pinnedListingId' in d.keys()) || (d.pinnedListingId is string
                                                  && d.pinnedListingId.size() <= 64));
    }

    // ─────────────────────────────────────────────
    // ORDERS — buyer or seller can read. Client cannot write; orders are
    // created by the Stripe webhook (Admin SDK).
    // ─────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if request.auth != null
                  && (resource.data.buyerId == request.auth.uid
                      || resource.data.sellerId == request.auth.uid);
      // Client cannot create or delete orders. The Stripe webhook owns
      // creation. Buyer + seller may transition fulfillmentStatus along
      // a strict path:
      //   awaiting_seller_shipment → shipped (seller adds tracking)
      //   shipped → delivered      (buyer confirms)
      //   delivered → reviewed     (set when buyer leaves a review;
      //                             written by review path elsewhere)
      allow update: if request.auth != null
        && appCheckOk()
        && (
          (request.auth.uid == resource.data.sellerId
            && resource.data.fulfillmentStatus == 'awaiting_seller_shipment'
            && request.resource.data.fulfillmentStatus == 'shipped'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
                 ['fulfillmentStatus','carrier','trackingNumber','shippedAt']))
          ||
          (request.auth.uid == resource.data.buyerId
            && resource.data.fulfillmentStatus == 'shipped'
            && request.resource.data.fulfillmentStatus == 'delivered'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
                 ['fulfillmentStatus','deliveredAt']))
        );
      allow create, delete: if false;
    }

    // ─────────────────────────────────────────────
    // CONVERSATIONS
    //   create: signed-in, creator is one of two participants, the *other*
    //           participant must be the listing's sellerId (so conversations
    //           can't be spammed at arbitrary UIDs), and listingId must
    //           refer to a real listing.
    //   update: only a whitelist of "last message" fields. participants /
    //           listingId / buyerId / sellerId are immutable.
    //   delete: never
    // ─────────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
        && appCheckOk()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants[0] != request.resource.data.participants[1]
        && request.resource.data.keys().hasAll(['participants','listingId','buyerId','sellerId','createdAt'])
        && request.resource.data.listingId is string
        && request.resource.data.listingId.size() > 0
        && request.resource.data.listingId.size() <= 128
        && exists(/databases/$(database)/documents/listings/$(request.resource.data.listingId))
        && get(/databases/$(database)/documents/listings/$(request.resource.data.listingId)).data.sellerId
             in request.resource.data.participants
        && request.resource.data.sellerId
             == get(/databases/$(database)/documents/listings/$(request.resource.data.listingId)).data.sellerId
        && request.resource.data.buyerId in request.resource.data.participants
        && request.resource.data.buyerId != request.resource.data.sellerId
        && (!('listingTitle' in request.resource.data.keys())
            || (request.resource.data.listingTitle is string
                && request.resource.data.listingTitle.size() <= 200))
        && (!('listingEmoji' in request.resource.data.keys())
            || (request.resource.data.listingEmoji is string
                && request.resource.data.listingEmoji.size() <= 16))
        && (!('lastMessageText' in request.resource.data.keys())
            || (request.resource.data.lastMessageText is string
                && request.resource.data.lastMessageText.size() <= 200));

      allow update: if request.auth != null
        && appCheckOk()
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['lastMessageAt','lastMessageText','lastMessageSenderId','lastRead'])
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.get('listingId', '') == resource.data.get('listingId', '')
        && request.resource.data.get('buyerId', '') == resource.data.get('buyerId', '')
        && request.resource.data.get('sellerId', '') == resource.data.get('sellerId', '')
        && (!('lastMessageText' in request.resource.data.keys())
            || (request.resource.data.lastMessageText is string
                && request.resource.data.lastMessageText.size() <= 200))
        && (!('lastMessageSenderId' in request.resource.data.keys())
            || request.resource.data.lastMessageSenderId == request.auth.uid);

      allow delete: if false;

      // ─────────────────────────────────────────────
      // MESSAGES
      //   Only participants can read. Only the sender (who must be a
      //   participant) can write a message, and the text is capped at 2000
      //   chars. Messages are immutable once sent.
      //
      //   BLOCK enforcement: deny create when the recipient (the OTHER
      //   participant) has blocked the sender — i.e. the sender's uid
      //   shows up as a key under users/{recipient}.blocked. We compute
      //   the recipient as participants[0] if sender is participants[1],
      //   else participants[1]. One extra get() per send; acceptable.
      //   If the recipient's user doc doesn't exist (fresh account
      //   that never wrote /users/{uid}), the get() returns no data
      //   and `.data.get('blocked', {})` falls back to an empty map.
      // ─────────────────────────────────────────────
      match /messages/{msgId} {
        function conv() {
          return get(/databases/$(database)/documents/conversations/$(convId)).data;
        }
        function recipientUid() {
          return conv().participants[0] == request.auth.uid
            ? conv().participants[1]
            : conv().participants[0];
        }
        function notBlockedByRecipient() {
          return !exists(/databases/$(database)/documents/users/$(recipientUid()))
            || !( request.auth.uid in
                  get(/databases/$(database)/documents/users/$(recipientUid())).data.get('blocked', {}).keys() );
        }
        allow read: if request.auth != null
                    && request.auth.uid in conv().participants;
        allow create: if request.auth != null
          && appCheckOk()
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in conv().participants
          && request.resource.data.keys().hasAll(['senderId','text','createdAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.createdAt == request.time
          && notBlockedByRecipient();
        allow update, delete: if false;
      }
    }

    // ─────────────────────────────────────────────
    // SAVED SEARCHES (top-level) — saved filter sets owners get
    // notified about when new matching listings appear. Distinct from
    // the legacy /users/{uid}/savedSearches subcollection above; this
    // top-level collection is the v1.1 home, scoped by userId field.
    //   read/write: owner only (userId == auth.uid)
    //   delete:     owner only
    // ─────────────────────────────────────────────
    match /savedSearches/{searchId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
        && appCheckOk()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId','name','query','notifyOnNew','createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.notifyOnNew is bool
        && request.resource.data.query is map
        && (!('category' in request.resource.data.query.keys())
            || (request.resource.data.query.category is string
                && request.resource.data.query.category.size() <= 40))
        && (!('brand' in request.resource.data.query.keys())
            || (request.resource.data.query.brand is string
                && request.resource.data.query.brand.size() <= 60))
        && (!('priceMin' in request.resource.data.query.keys())
            || (request.resource.data.query.priceMin is number
                && request.resource.data.query.priceMin >= 0))
        && (!('priceMax' in request.resource.data.query.keys())
            || (request.resource.data.query.priceMax is number
                && request.resource.data.query.priceMax >= 0))
        && (!('condition' in request.resource.data.query.keys())
            || (request.resource.data.query.condition is string
                && request.resource.data.query.condition.size() <= 40));

      allow update: if request.auth != null
        && appCheckOk()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['name','query','notifyOnNew','updatedAt'])
        && (!('name' in request.resource.data.keys())
            || (request.resource.data.name is string
                && request.resource.data.name.size() > 0
                && request.resource.data.name.size() <= 80))
        && (!('notifyOnNew' in request.resource.data.keys())
            || request.resource.data.notifyOnNew is bool);

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────
    // OFFERS — make-an-offer feature. Buyer pitches a price; seller
    // accepts/declines/counters. Once created, offers are immutable
    // history (status walks forward, body never deleted).
    //   read:   buyer or seller of the offer
    //   create: any auth user as buyer; status must start 'pending'
    //   update: seller can transition status to accepted/declined/
    //           countered (and set counterAmount). Buyer can edit
    //           their own `message` while still pending.
    //   delete: never (expiry is encoded as status='expired' by a
    //           Cloud Function, not by deletion)
    // ─────────────────────────────────────────────
    match /offers/{offerId} {
      allow read: if request.auth != null
                  && (resource.data.buyerId == request.auth.uid
                      || resource.data.sellerId == request.auth.uid);

      allow create: if request.auth != null
        && appCheckOk()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.keys().hasAll(
             ['buyerId','sellerId','listingId','amount','status','createdAt','expiresAt'])
        && request.resource.data.status == 'pending'
        && request.resource.data.listingId is string
        && request.resource.data.listingId.size() > 0
        && request.resource.data.listingId.size() <= 128
        && exists(/databases/$(database)/documents/listings/$(request.resource.data.listingId))
        && request.resource.data.sellerId
             == get(/databases/$(database)/documents/listings/$(request.resource.data.listingId)).data.sellerId
        && request.resource.data.sellerId != request.auth.uid
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount < 1000000
        && (!('message' in request.resource.data.keys())
            || (request.resource.data.message is string
                && request.resource.data.message.size() <= 500))
        && !('counterAmount' in request.resource.data.keys());

      allow update: if request.auth != null
        && appCheckOk()
        && resource.data.status == 'pending'
        && (
          // Seller transitions: accepted | declined | countered.
          (request.auth.uid == resource.data.sellerId
            && request.resource.data.status in ['accepted','declined','countered']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
                 ['status','counterAmount','respondedAt'])
            && (!('counterAmount' in request.resource.data.keys())
                || (request.resource.data.counterAmount is number
                    && request.resource.data.counterAmount > 0
                    && request.resource.data.counterAmount < 1000000))
            // counterAmount only legal when status == 'countered'.
            && (request.resource.data.status == 'countered'
                || !('counterAmount' in request.resource.data.diff(resource.data).affectedKeys())))
          ||
          // Buyer can set message ONCE if not previously set (prevents
          // spam-edit cost attack). To change, buyer must withdraw + re-create.
          (request.auth.uid == resource.data.buyerId
            && request.resource.data.status == 'pending'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['message'])
            && !('message' in resource.data.keys())
            && request.resource.data.message is string
            && request.resource.data.message.size() <= 500)
        );

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // REFERRALS — one doc per referral code. Doc id IS the code.
    // Public read so anyone can validate a code at signup. Creates
    // and updates are server-only (Cloud Function mints codes and
    // appends to `usedBy`).
    // ─────────────────────────────────────────────
    match /referrals/{referralCode} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // DAILY GAMES — REMOVED 2026-05-12 (superseded). See BINGO_CACHING_AUDIT.md.
    //
    // DAILY PUZZLES — REINTRODUCED for cross-platform parity. The new
    // /dailyPuzzles/{YYYY-MM-DD} collection is written exclusively by
    // the generateDailyBingoPuzzle scheduled Cloud Function (Admin SDK
    // bypasses these rules). Clients read it to render the same 9 logos
    // on web and iOS — see LOGO_BINGO_DIAGNOSIS.md for the bug this
    // fixes. Public read so anonymous users can still play; client
    // writes always denied so the doc remains canonical.
    // ─────────────────────────────────────────────
    match /dailyPuzzles/{date} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // GAME SCORES — Logo Bingo leaderboard. Doc id is `{date}_{uid}`
    // so each user gets one score per daily puzzle. Public read so
    // top-N leaderboard queries work. Streak field is the only thing
    // a client may rewrite (and only their own doc) — Cloud Functions
    // perform the authoritative streak math server-side.
    // ─────────────────────────────────────────────
    match /gameScores/{scoreId} {
      allow read: if true;

      allow create: if request.auth != null
        && appCheckOk()
        && request.resource.data.userId == request.auth.uid
        && scoreId == request.resource.data.date + '_' + request.auth.uid
        && request.resource.data.keys().hasAll(
             ['userId','date','correctCount','attempts','completedAt'])
        && request.resource.data.date is string
        && request.resource.data.date.size() == 10
        && request.resource.data.correctCount is int
        && request.resource.data.correctCount >= 0
        && request.resource.data.correctCount <= 9
        && request.resource.data.attempts is int
        && request.resource.data.attempts >= 0
        && request.resource.data.attempts <= 1000
        && (!('streak' in request.resource.data.keys())
            || (request.resource.data.streak is int
                && request.resource.data.streak >= 0));

      // Streak is server-computed via Cloud Functions — clients can't update
      // their own score after creation. Prevents spam-update cost attack.
      allow update: if false;

      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // BINGO LEADERBOARDS — pre-aggregated histogram of Logo Bingo solve
    // times per day. Doc id is YYYY-MM-DD (mirrors dailyGames). Owned
    // by the onBingoWinAggregate trigger (Admin SDK); clients only
    // read. Auth required so anonymous scrapers can't snapshot the
    // histogram, and to attribute load to identified users.
    //   bingoLeaderboard/{date}                 → global histogram
    //   bingoLeaderboard/{date}/countries/{cc}  → country-scoped histogram
    // ─────────────────────────────────────────────
    match /bingoLeaderboard/{date} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;

      match /countries/{countryCode} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }
    }

    // ─────────────────────────────────────────────
    // BINGO GLOBAL STATS — singleton doc tracking the all-time longest
    // Logo Bingo streak (and the currently active leader). Written by
    // onBingoWinAggregate (Admin SDK) only.
    // ─────────────────────────────────────────────
    match /bingoGlobalStats/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // FLAGGED LISTINGS — manual moderation queue. Mirror of any
    // listing that Cloud Vision SafeSearch trips on. Cloud Functions
    // (Admin SDK) own all writes; admin emails can read + delete
    // (delete = "I've handled this, clear it from the queue").
    // ─────────────────────────────────────────────
    match /flaggedListings/{listingId} {
      allow read: if isAdmin();
      allow create, update: if false; // Cloud Functions only.
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // MESSAGE FLAGS — server-written audit trail for chat messages
    // tripped by the moderateMessage Firestore trigger. The sender
    // and recipient can read their own flagged-exchange records;
    // admins read all. Only Cloud Functions (Admin SDK) write here.
    // ─────────────────────────────────────────────
    match /messageFlags/{flagId} {
      allow read: if request.auth != null &&
                  (resource.data.senderId == request.auth.uid ||
                   resource.data.recipientId == request.auth.uid ||
                   isAdmin());
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // MESSAGING CONFIG — tunable rate-limit knobs read by the
    // sendMessage callable on every send (cached 60s in-memory by
    // each function instance). Any signed-in user can read so the
    // client could in theory surface the current limits in UX
    // copy; only admins may write the doc. The Cloud Function
    // bypasses these rules via Admin SDK on first-read seeding.
    // ─────────────────────────────────────────────
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // MESSAGE HOLDS — queue of chat messages that the sendMessage
    // callable refused to deliver (duplicate-spam pattern, repeat
    // PII to the same recipient). Sender can read their own held
    // messages so we can surface "in review" UX; admin reads the
    // full queue for moderation. All writes go through Admin SDK
    // (the sendMessage callable + admin release/reject actions).
    // ─────────────────────────────────────────────
    match /messageHolds/{holdId} {
      allow read: if request.auth != null
                  && (resource.data.sender == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // PRESENCE — lightweight per-user "what am I looking at right now"
    // doc used by pushOnNewMessage to skip pushes for a recipient who
    // is already in the conversation. Best-effort, not a security tool;
    // we still trust client wiring to write currentlyViewingConversation
    // honestly. Stale docs (closed app) self-expire because the trigger
    // checks lastHeartbeatAt within a 30s window.
    // ─────────────────────────────────────────────
    match /presence/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────
    // PUSH PENDING — server-side coalescing bookkeeping for the
    // pushOnNewMessage trigger. Doc id is recipientId_senderId_cid.
    // Cloud Functions only.
    // ─────────────────────────────────────────────
    match /pushPending/{pendingId} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────
    // FOUNDER BRIEFINGS — daily AI-generated marketplace summary, doc id
    // is the report date (YYYY-MM-DD). Written exclusively by the
    // dailyFounderBriefing Cloud Function (Admin SDK bypasses these
    // rules). Contains aggregate GMV / order counts / dispute counts /
    // baseline z-scores and the Claude-generated briefing text — all of
    // which is sensitive enough that we deny ALL client access (including
    // admin reads — view via the Firebase Console or a server-side
    // admin tool instead).
    // ─────────────────────────────────────────────
    match /founderBriefings/{date} {
      allow read, create, update, delete: if false;
    }

    // ─────────────────────────────────────────────
    // DEFAULT DENY
    // ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
