<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>TeeBox</string>
	<key>NSCameraUsageDescription</key>
	<string>TeeBox uses the camera to take photos of items you list for sale.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>TeeBox lets you choose photos from your library for your listings and your profile picture.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>TeeBox can save listing receipts and order confirmations to your photo library.</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<!-- We register for APNs and forward the token to Firebase Auth manually
	     in AppDelegate.application(_:didRegisterForRemoteNotificationsWithDeviceToken:).
	     Disabling Firebase's auto-proxy stops it from competing with our handler,
	     which was eating the verificationId on phone-auth. -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
	<!-- Google OAuth callback. The URL scheme MUST equal REVERSED_CLIENT_ID
	     from GoogleService-Info.plist (looks like com.googleusercontent.apps.NNN-XXX).
	     Re-download GoogleService-Info.plist from Firebase Console after enabling
	     Google Sign-In, then paste the REVERSED_CLIENT_ID below. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>REPLACE_WITH_REVERSED_CLIENT_ID</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
